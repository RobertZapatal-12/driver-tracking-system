            print(f"✅ Login exitoso: {email}")
            print(f"   Token: {data['token'][:20]}...")
            print(f"   Usuario: {data['user']['name']}")
            return True
        else:
            print(f"❌ Login fallido: {response.json().get('detail', 'Error desconocido')}")
            return False
            
    except Exception as e:
