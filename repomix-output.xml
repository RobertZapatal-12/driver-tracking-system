    except:
        print(f"❌ No se puede conectar a {API_BASE}")
        print("   Asegúrate de que el backend esté corriendo:")
        print("   python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000")
        sys.exit(1)
    
    # Crear usuarios
